{
  "manifest_version": 3,
  "name": "ISACC2 Post Predictor",
  "version": "1.0.5",
  "description": "Predicts next post/comment numbers and milestone ETAs on isacc2.com forums.",

  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.isacc2.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.isacc2.com/forums/*"],
      "js": ["src/content.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_idle"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "isacc2-dubs-predictor@extension",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
